# BioaxisOS — environment template. Copy to .env.local for dev; set these in Netlify.
# NEVER commit real secrets. PHI never appears in any of these values.

# --- App ---
APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Auth ---
# 32+ char random string. Generate: openssl rand -base64 32
AUTH_SECRET=""

# --- Database (DigitalOcean Managed Postgres) ---
# DO requires TLS. Use the *pooled* connection string (PgBouncer, port 25061) for
# serverless/Netlify, and append ?sslmode=require.
# Example: postgresql://doadmin:PASS@db-bioaxisos-do-user-0-0.b.db.ondigitalocean.com:25061/bioaxisos?sslmode=require
DATABASE_URL=""
# DigitalOcean CA cert (base64 or PEM path) — required for strict TLS verification in prod.
DATABASE_CA_CERT=""

# --- Email transport (Phase 1 wiring; transport carries NO PHI — links only) ---
EMAIL_FROM="BioaxisOS <no-reply@bioaxis.renuviamd.com>"
EMAIL_API_KEY=""

# --- Build ---
# Set to "1" to skip Zod env validation during CI builds without secrets.
SKIP_ENV_VALIDATION=""
