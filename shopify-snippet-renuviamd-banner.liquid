{% comment %}
  ============================================
  RENUVIAMD TELEHEALTH BANNER
  Add to theme: snippets/renuviamd-banner.liquid
  Include in header or announcement bar
  ============================================
{% endcomment %}

<style>
  .renuviamd-banner {
    background: linear-gradient(135deg, #1E3D32, #162C24);
    border-bottom: 1px solid rgba(212, 170, 76, 0.2);
    padding: 12px 16px;
    text-align: center;
  }
  .renuviamd-banner__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
  }
  .renuviamd-banner__text {
    font-size: 13px;
    color: #F5F0E1;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .renuviamd-banner__highlight {
    color: #D4AA4C;
    font-weight: 600;
  }
  .renuviamd-banner__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(212, 170, 76, 0.15);
    border: 1px solid rgba(212, 170, 76, 0.3);
    color: #D4AA4C;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .renuviamd-banner__link:hover {
    background: #D4AA4C;
    color: #0F1512;
  }
  @media (max-width: 600px) {
    .renuviamd-banner__inner {
      flex-direction: column;
      gap: 8px;
    }
    .renuviamd-banner__text {
      font-size: 12px;
    }
  }
</style>

<div class="renuviamd-banner">
  <div class="renuviamd-banner__inner">
    <span class="renuviamd-banner__text">
      💊 Need a GLP-1 Prescription? Brand meds <span class="renuviamd-banner__highlight">$350/mo via TrumpRx</span>
    </span>
    <a href="https://renuviamd.com" target="_blank" class="renuviamd-banner__link">
      Visit RenuviaMD™ →
    </a>
  </div>
</div>
